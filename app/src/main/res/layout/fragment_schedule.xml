<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ===================== ЭКРАН 1: НЕДЕЛЯ (главный) ===================== -->
    <LinearLayout
        android:id="@+id/screen_week"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Заголовок -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tv_week_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="Расписание"/>

            <TextView
                android:id="@+id/btn_calendar_open"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:gravity="center"
                android:text="&#128197;"
                android:textSize="22sp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>
        </RelativeLayout>

        <!-- Список дней -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_week_days"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"/>

        <!-- Навигация -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btn_week_prev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#171;"
                android:textColor="@color/primary"
                android:textSize="32sp"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

            <View android:layout_width="40dp" android:layout_height="1dp"/>

            <TextView
                android:id="@+id/btn_week_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#187;"
                android:textColor="@color/primary"
                android:textSize="32sp"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===================== ЭКРАН 2: КАЛЕНДАРЬ ===================== -->
    <LinearLayout
        android:id="@+id/screen_calendar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Заголовок -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/btn_calendar_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:gravity="center"
                android:text="&#8592;"
                android:textColor="@color/primary"
                android:textSize="24sp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/tv_calendar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </RelativeLayout>

        <!-- Карточка с календарём -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:id="@+id/calendar_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"/>
            </androidx.cardview.widget.CardView>
        </FrameLayout>

        <!-- Навигация -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btn_cal_prev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#171;"
                android:textColor="@color/primary"
                android:textSize="32sp"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

            <View android:layout_width="40dp" android:layout_height="1dp"/>

            <TextView
                android:id="@+id/btn_cal_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#187;"
                android:textColor="@color/primary"
                android:textSize="32sp"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ===================== ЭКРАН 3: ЗАНЯТИЯ ДНЯ ===================== -->
    <LinearLayout
        android:id="@+id/screen_day"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Кнопка назад -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="8dp">

            <TextView
                android:id="@+id/btn_day_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:text="&#8592;"
                android:textColor="@color/primary"
                android:textSize="24sp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>
        </RelativeLayout>

        <!-- Карточка дня -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_day_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:paddingTop="20dp"
                    android:paddingBottom="2dp"/>

                <TextView
                    android:id="@+id/tv_day_date_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:paddingBottom="12dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_day_lessons"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:clipToPadding="false"/>

                <TextView
                    android:id="@+id/tv_no_lessons"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:text="Нет занятий"
                    android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Навигация -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btn_day_prev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#171;"
                android:textColor="@color/primary"
                android:textSize="32sp"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

            <View android:layout_width="40dp" android:layout_height="1dp"/>

            <TextView
                android:id="@+id/btn_day_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#187;"
                android:textColor="@color/primary"
                android:textSize="32sp"
                android:padding="16dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
